# ============================================================
# J.A.R.V.I.S. Command Center — environment configuration
# Copy to .env and fill in. The BFF reads these; the web app
# never sees the hermes key (it only talks to the BFF).
# ============================================================

# ---- BFF server ----
PORT=8787
HOST=0.0.0.0
# Comma-separated list of allowed browser origins for the BFF CORS layer.
# In single-origin production (Nginx or SERVE_WEB), set this to the public site URL.
WEB_ORIGIN=http://localhost:5173

# Shared secret guarding the BFF. The BFF proxies into hermes' agent (which can
# run terminal commands), so a publicly-reachable deployment MUST set this and/or
# sit behind an authenticating reverse proxy. When set, Nginx forwards it (see
# nginx.conf) so the browser never holds it. Leave empty only for loopback/dev.
BFF_API_KEY=

# Single-process mode: let the BFF serve the built web app (SPA) itself.
# Leave false when Nginx serves the static build (the compose default).
SERVE_WEB=false
# WEB_DIR=/app/web            # absolute path to apps/web/dist when SERVE_WEB=true

# Boot lifecycle (containers): run schema migration on start, and seed.
MIGRATE_ON_BOOT=true
# SEED_ON_BOOT: "true" always seeds, "false" never; unset = auto-seed only if empty.
# SEED_ON_BOOT=

# ---- hermes-agent (NousResearch) on the Hostinger VPS ----
# The gateway base URL. Prefer the private/loopback or a TLS-terminated
# reverse proxy — do NOT expose hermes publicly unauthenticated: its API
# grants the agent's full toolset, including terminal commands.
# Examples:
#   http://127.0.0.1:8642           (BFF co-located on the VPS — recommended)
#   https://hermes.your-domain.tld  (behind Traefik/HTTPS)
HERMES_BASE_URL=http://127.0.0.1:8642
# The Bearer token = the API_SERVER_KEY you set in ~/.hermes/.env on the VPS.
HERMES_API_KEY=change-me
# Stable per-operator session key -> hermes long-term memory (X-Hermes-Session-Key).
HERMES_SESSION_KEY=operator-primary
# Model the app requests from hermes. Use a Claude model; hermes routes it via
# its configured provider (e.g. Nexos.ai). Matches the deployed hermes default.
HERMES_MODEL=claude-sonnet-4-6
# Hostinger Hermes dashboard login (session-cookie auth). When set, the BFF logs
# in and calls /v1/chat/completions with the cookie — this is how live Claude
# chat is wired on the Hostinger template (the dashboard has no bearer API key).
# HERMES_DASH_USER=hermes_lonee
# HERMES_DASH_PASS=your-hermes-dashboard-password

# ---- Postgres (BFF-owned domains: agents, tasks, calendar, KB, costs) ----
# Point at a DB on the same VPS or a managed instance.
DATABASE_URL=postgres://jarvis:jarvis@127.0.0.1:5432/jarvis
# Set to "true" if your managed Postgres requires TLS.
DATABASE_SSL=false

# ---- Web app (Vite) ----
# Base URL the browser uses to reach the BFF. Empty = same-origin (prod behind a
# proxy); set to the BFF URL for local dev.
VITE_API_BASE=http://localhost:8787
# Only for the single-process/dev path where no Nginx injects the key. In the
# Nginx-fronted deploy, leave this empty and let the proxy add X-API-Key.
# VITE_BFF_API_KEY=
